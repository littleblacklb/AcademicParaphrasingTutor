# AI Provider Configuration
# Supports any OpenAI-compatible API (Gemini, DeepSeek, OpenAI, etc.)

# Required: Your API key
AI_API_KEY=

# Base URL for the AI provider (defaults to Gemini)
# Gemini:   https://generativelanguage.googleapis.com/v1beta/openai/
# DeepSeek: https://api.deepseek.com
# OpenAI:   https://api.openai.com/v1
AI_BASE_URL=https://api.deepseek.com

# Model name (defaults to gemini-2.0-flash)
# Gemini:   gemini-2.0-flash, gemini-2.5-pro-preview-05-06
# DeepSeek: deepseek-chat
# OpenAI:   gpt-4o
AI_MODEL=gemini-2.0-flash

# Thinking level (e.g. low, medium, high - maps to reasoning_effort for compatible models)
AI_THINKING_LEVEL=high
